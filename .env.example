# =========================================================================
# KAMPUNG SIBER RETRO - UNIFIED ENVIRONMENT TEMPLATE (.env.example)
# =========================================================================
# Arahan: Salin fail ini menjadi .env.local untuk pembangunan tempatan.
# AMARAN KESELAMATAN (Rule 35): JANGAN SESEKALI menolak atau komit fail .env.local
# yang mengandungi kredensi sebenar ke dalam repositori Git / GitHub.
# =========================================================================

# -------------------------------------------------------------------------
# 1. Next Auth / Auth.js Configuration
# -------------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key-at-least-32-characters"

# -------------------------------------------------------------------------
# 2. OSTEEM CONFIGURATION BLOCK - SUPABASE VERSION 01 (Core/Backup Tier)
# -------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_KEY="your-anon-public-key-here"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key-here"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-jwt-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-jwt-service-role-key-keep-safe"

# Database Connections (Direct & Pooled Connection Strings)
# Pooled Connection (Port 6543) - Sesuai untuk runtime serverless Next.js
DATABASE_URL="postgresql://postgres.your-project-id:your-password@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DATABASE_URL_POOLED="postgresql://postgres.your-project-id:your-password@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct Connection (Port 5432) - Sesuai untuk proses migrasi (Prisma/Drizzle)
DIRECT_URL="postgresql://postgres.your-project-id:your-password@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"
DATABASE_URL_DIRECT="postgresql://postgres.your-project-id:your-password@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# OAuth and Authentication Keys (Core Tier)
PUBLISHABLE_KEY="your-publishable-oauth-key"
SECRET_KEY="your-secret-oauth-key"
CALLBACK_URL_FOR_OAUTH="https://your-project-id.supabase.co/auth/v1/callback"
SUPABASE_JWKS_URL="https://your-project-id.supabase.co/auth/v1/.well-known/jwks.json"

# -------------------------------------------------------------------------
# 3. OSTEEM CONFIGURATION BLOCK - SUPABASE VERSION 02 (Isolated Secure Tier)
# -------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL_SECURE="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY_SECURE="your-publishable-secure-key"
NEXT_PUBLIC_SUPABASE_ANON_KEY_SECURE="your-secure-jwt-anon-key"
SUPABASE_SERVICE_ROLE_KEY_SECURE="your-secure-jwt-service-role-key"
SUPABASE_JWKS_URL_SECURE="https://your-project-id.supabase.co/auth/v1/.well-known/jwks.json"

# OAuth & Authentication Keys (Secure Tier)
PUBLISHABLE_KEY_SECURE="your-publishable-secure-oauth-key"
SECRET_KEY_SECURE="your-secret-secure-oauth-key"
CALLBACK_URL_FOR_OAUTH_SECURE="https://your-project-id.supabase.co/auth/v1/callback"

# Database Connections (Secure Tier with Explicit SSL Routing)
DATABASE_URL_SECURE="postgresql://postgres.your-project-id:your-password@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL_SECURE="postgresql://postgres.your-project-id:your-password@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require"

# -------------------------------------------------------------------------
# 4. Cloudflare R2 Storage (Default Configuration)
# -------------------------------------------------------------------------
CLOUDFLARE_R2_ACCOUNT_ID="your-cloudflare-account-id"
CLOUDFLARE_R2_ACCESS_KEY_ID="your-r2-access-key-id"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
CLOUDFLARE_R2_PUBLIC_URL="https://pub-your-unique-r2-id.r2.dev"
CLOUDFLARE_R2_BUCKET_NAME="your-r2-bucket-name"

# -------------------------------------------------------------------------
# 5. Cloudflare R2 Storage (Alternative S3-Compatible Format Key)
# -------------------------------------------------------------------------
R2_ACCESS_KEY_ID="your-alternative-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-alternative-r2-secret-access-key"
R2_ENDPOINT="https://your-cloudflare-account-id.r2.cloudflarestorage.com"
R2_BUCKET_NAME="your-alternative-r2-bucket-name"

# -------------------------------------------------------------------------
# 6. Upstash Redis Configuration (Rate Limiting Control)
# -------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL="https://your-redis-instance-name.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-rest-token-string"