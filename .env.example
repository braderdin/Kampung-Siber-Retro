# ==========================================
# Kampung Siber Retro — Environment Template
# Copy to your local env file for development.
# NEVER commit the real local env file (Rule 35 Security Guard).
# ==========================================

# Supabase public project URL (browser-exposed). Required for auth + DB.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (browser-exposed, RLS-protected).
NEXT_PUBLIC_SUPABASE_KEY=your-anon-public-key

# Supabase service role key (server-only, bypasses RLS). Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
