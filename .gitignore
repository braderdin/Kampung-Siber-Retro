/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing Outputs
/coverage

# Next.js 15 App Router & Production Builds
/.next/
/out/
/build
dist/

# System Configuration & Garbage Files
.DS_Store
Thumbs.db
*.pem
*.key

# Runtime Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
devsrv.log
devsrv.err
tsc_out.txt

# Local Environment Secrets (Dynamic Token Envs)
.env
.env.local
.env.development.local
.env.production.local
.env.test.local
.env*.local

# Vercel Deployment Configurations
.vercel

# AI Agents & Automation Workspaces
.aider*
.cline/

# Python Virtual Environments
venv/
.venv/

# Legacy Corporate Workspaces
scripts/archive/
logs/